{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghrabuvka.cz/schemas/ghrab-material-v1.schema.json",
  "title": "GHRAB Material v1",
  "description": "Serverless výměnný formát pro materiály mezi aplikacemi AI Studio GHRAB.",
  "type": "object",
  "required": ["schema", "id", "version", "title", "subject", "objectives", "content", "quality"],
  "properties": {
    "schema": {"const": "ghrab-material-v1"},
    "id": {"type": "string", "minLength": 3},
    "version": {"type": "integer", "minimum": 1},
    "title": {"type": "string", "minLength": 1},
    "subject": {"type": "string", "minLength": 1},
    "yearGroup": {"type": "string"},
    "level": {"type": "string"},
    "language": {"type": "string"},
    "objectives": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "content": {
      "type": "object",
      "required": ["sourceText"],
      "properties": {
        "sourceText": {"type": "string"},
        "vocabulary": {"type": "array", "items": {"type": "string"}},
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "prompt"],
            "properties": {
              "id": {"type": "string"},
              "type": {"enum": ["select", "truefalse", "short", "open", "order"]},
              "prompt": {"type": "string"},
              "options": {"type": "array", "items": {"type": "string"}},
              "answer": {},
              "explanation": {"type": "string"},
              "difficulty": {"type": "integer", "minimum": 1, "maximum": 3}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "differentiation": {"type": "object"},
    "quality": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"enum": ["ai-draft", "teacher-reviewed", "classroom-tested", "commission-reviewed"]},
        "reviewedAt": {"type": ["string", "null"]},
        "reviewedByRole": {"type": "string"},
        "checks": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "provenance": {"type": "object"},
    "workflow": {"type": "object"}
  },
  "additionalProperties": true
}
