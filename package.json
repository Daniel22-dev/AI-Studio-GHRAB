{
  "name": "ai-studio-ghrab",
  "version": "0.18.3",
  "private": true,
  "description": "Profesionální PWA ekosystém šesti školních AI nástrojů s ACTIVA, rozšířenými manuály, řízeným přístupem a jednotnou GHRAB QA bránou",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-registry.mjs",
    "sync:offline": "node scripts/sync-registry.mjs --offline",
    "build": "npm run generate:changelog && node scripts/build.mjs",
    "test": "npm run generate:changelog && npm run format:check && node scripts/test.mjs",
    "check": "node scripts/test.mjs",
    "generate:changelog": "node scripts/generate-changelog.mjs",
    "format": "prettier --write \"src/**/*.{js,css,html,json,webmanifest,md}\" \"scripts/**/*.mjs\" \".github/**/*.yml\" \"*.md\" \"package.json\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html,json,webmanifest,md}\" \"scripts/**/*.mjs\" \".github/**/*.yml\" \"*.md\" \"package.json\"",
    "qa:technical": "node scripts/qa-technical.mjs",
    "qa:security": "node scripts/qa-security.mjs",
    "qa:pwa": "node scripts/qa-pwa.mjs",
    "qa:critical": "node scripts/qa-critical.mjs",
    "qa:visual": "node scripts/qa-visual.mjs",
    "qa:report": "node scripts/qa-report.mjs",
    "qa:approve": "node scripts/qa-approve.mjs",
    "qa:release": "node scripts/qa-release.mjs",
    "qa:combinatorial": "node scripts/qa-combinatorial.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.5"
  }
}
