{
  "name": "ai-studio-ghrab",
  "version": "0.16.7",
  "private": true,
  "description": "Profesionální PWA rozcestník školních AI nástrojů s elegantní filmovou animací spuštění, instalační výzvou pro PC, řízeným přístupem a odolným GitHub buildem",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-registry.mjs && npm run format:generated",
    "sync:offline": "node scripts/sync-registry.mjs --offline && npm run format:generated",
    "build": "npm run generate:changelog && node scripts/build.mjs",
    "test": "npm run generate:changelog && npm run format:check && node scripts/test.mjs",
    "check": "node scripts/test.mjs",
    "generate:changelog": "node scripts/generate-changelog.mjs",
    "format": "prettier --write \"src/**/*.{js,css,html,json,webmanifest,md}\" \"scripts/**/*.mjs\" \".github/**/*.yml\" \"*.md\" \"package.json\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html,json,webmanifest,md}\" \"scripts/**/*.mjs\" \".github/**/*.yml\" \"*.md\" \"package.json\"",
    "format:generated": "prettier --write \"src/config/apps.generated.json\" \"src/config/sync-report.json\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "prettier": "^3.9.5"
  }
}
