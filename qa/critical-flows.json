{
  "flows": [
    {
      "id": "STUDIO-OPEN",
      "name": "Otevření centrálního rozcestníku",
      "type": "browser",
      "url": "/index.html",
      "expectedText": "AI Studio GHRAB",
      "steps": [
        {
          "action": "clickIfVisible",
          "selector": "#studio-startup-skip",
          "timeout": 5000
        },
        {
          "action": "wait",
          "ms": 650
        },
        {
          "action": "assertVisible",
          "selector": "main#main"
        }
      ]
    },
    {
      "id": "STUDIO-CACHE-ISOLATION",
      "name": "Service worker nemaže cizí cache",
      "type": "static",
      "assertions": [
        {
          "file": "src/sw.js",
          "regex": "startsWith\\(\"ai-studio-ghrab-v\"\\)",
          "message": "Aktivace service workeru není omezena na vlastní prefix."
        }
      ]
    },
    {
      "id": "STUDIO-ACTIVA-INTEGRATION",
      "name": "ACTIVA je v registru, politice a manuálech",
      "type": "static",
      "assertions": [
        {
          "file": "src/config/apps.fallback.json",
          "regex": "\\\"id\\\"\\s*:\\s*\\\"activity-builder\\\"",
          "message": "Fallback registr neobsahuje ACTIVA."
        },
        {
          "file": "src/config/access-policy.json",
          "regex": "\\\"trainingCode\\\"\\s*:\\s*\\\"ACT-01\\\"",
          "message": "ACTIVA nemá školení ACT-01."
        },
        {
          "file": "src/manualy/manualy.js",
          "regex": "activity-builder",
          "message": "Centrum manuálů nemá obsah ACTIVA."
        }
      ]
    }
  ]
}
