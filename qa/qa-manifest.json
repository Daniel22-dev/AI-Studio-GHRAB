{
  "standard": "GHRAB-QA-1.0.2",
  "appId": "ai-studio-ghrab",
  "appName": "AI Studio GHRAB",
  "appVersion": "0.17.5",
  "entryPoint": "dist/index.html",
  "serveRoot": "dist",
  "buildRoot": "dist",
  "installCommand": "npm ci --no-fund",
  "buildCommand": "npm run build",
  "testCommand": "npm test",
  "headlessCommand": "",
  "auditCommand": "npm audit --audit-level=high",
  "features": {
    "pwa": true,
    "ai": false,
    "centralAccessGuard": true,
    "fileExport": true,
    "studentRuntime": false,
    "teacherRuntime": true,
    "localStorage": true,
    "serviceWorker": true
  },
  "requiredViewports": [
    {
      "width": 360,
      "height": 800
    },
    {
      "width": 412,
      "height": 915
    },
    {
      "width": 768,
      "height": 1024
    },
    {
      "width": 1366,
      "height": 768
    },
    {
      "width": 1920,
      "height": 1080
    }
  ],
  "versionChecks": [
    {
      "file": "src/config/changelog.json",
      "regex": "\"current\"\\s*:\\s*\"([0-9.]+)\"",
      "expected": "0.17.5"
    },
    {
      "file": "dist/build-info.json",
      "regex": "\"version\"\\s*:\\s*\"([0-9.]+)\"",
      "expected": "0.17.5"
    },
    {
      "file": "dist/sw.js",
      "regex": "ai-studio-ghrab-v([0-9.]+)",
      "expected": "0.17.5"
    }
  ],
  "pwaTargets": [
    {
      "id": "ai-studio",
      "root": "dist",
      "manifest": "manifest.webmanifest",
      "serviceWorker": "sw.js",
      "cachePrefix": "ai-studio-ghrab-v"
    }
  ],
  "security": {
    "allowedEmails": [
      "balaz@ghrabuvka.cz"
    ],
    "requiresCsvFormulaProtection": false
  },
  "compatibility": {
    "runtimeSourceRoots": [
      "src",
      "public"
    ],
    "disallowRegexLookbehind": true
  }
}
