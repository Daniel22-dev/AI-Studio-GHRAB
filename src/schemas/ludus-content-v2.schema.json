{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghrabuvka.cz/schemas/ludus-content-v2.schema.json",
  "title": "LUDUS Content v2",
  "type": "object",
  "required": [
    "schema",
    "kind",
    "schemaVersion",
    "game",
    "meta",
    "lang",
    "theme",
    "flow",
    "stations"
  ],
  "properties": {
    "schema": { "const": 2 },
    "kind": { "const": "ludus.content" },
    "schemaVersion": { "const": "ludus-content-v2" },
    "game": { "type": "object" },
    "meta": { "type": "object" },
    "lang": { "type": "object" },
    "theme": { "type": "object" },
    "exerciseTypes": { "type": "array", "items": { "type": "string" } },
    "flow": { "type": "object" },
    "teams": { "type": ["array", "object"] },
    "stations": { "type": "array", "items": { "type": "object" } },
    "finalChallenge": {}
  },
  "additionalProperties": true
}
